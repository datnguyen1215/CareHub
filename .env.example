# Domain
APP_DOMAIN=care.dnguyen.us
ACME_EMAIL=your-email@example.com

# Database
POSTGRES_USER=carehub
POSTGRES_PASSWORD=carehub_dev
POSTGRES_DB=carehub
DATABASE_URL=postgresql://carehub:carehub_dev@localhost:9392/carehub
DATABASE_URL_TEST=postgresql://carehub:carehub_dev@localhost:9392/carehub_test

# Auth
JWT_SECRET=change-me-to-a-random-string

# SMTP (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=carehub.notifications@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=CareHub

# App
NODE_ENV=development
PORT=9391
FRONTEND_URL=http://localhost:9390

# Logging
LOG_LEVEL=info
LOG_FILE=
LOG_FORMAT=pretty

# AI Models
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-haiku-20240307
