<?xml version="1.0" encoding="utf-8"?>
<!--
    Device admin policy declarations for the CareHub Kiosk app.

    This file is referenced by the DeviceAdminReceiver component in AndroidManifest.xml.
    No specific policies need to be declared here: when the app is set as Device Owner,
    Android grants it all device administration privileges by definition. The
    <uses-policies> block is intentionally empty — all capabilities (including silent
    APK installation) come from Device Owner status, not from individual policy tags.
-->
<device-admin>
    <uses-policies />
</device-admin>
