# CareHub Backend Environment Variables

# Server
NODE_ENV=development
PORT=9391

# Database
DATABASE_URL=postgresql://carehub:carehub_dev@localhost:9392/carehub
DATABASE_URL_TEST=postgresql://carehub:carehub_dev@localhost:9392/carehub_test

# SMTP (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@carehub.local

# Logging
LOG_LEVEL=info
LOG_FILE=/tmp/carehub/backend.log
LOG_FORMAT=pretty

# Storage
STORAGE_PROVIDER=local
UPLOADS_PATH=./uploads
UPLOADS_URL_PREFIX=/uploads

# OCR Configuration
# Options: 'google' (Google Cloud Vision) or 'tesseract' (local, no API key needed)
OCR_PROVIDER=tesseract

# Google Cloud Vision (required when OCR_PROVIDER=google)
# Path to service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GOOGLE_CLOUD_PROJECT=your-project-id

# AI Configuration
# Options: 'openai', 'anthropic', or 'fallback' (heuristic-based, no API key needed)
AI_PROVIDER=fallback

# OpenAI (required when AI_PROVIDER=openai)
OPENAI_API_KEY=

# Anthropic (required when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
